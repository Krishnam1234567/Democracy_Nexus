{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "quizScores": {
      ".read": "auth != null",
      "$scoreId": {
        ".create": "auth != null",
        ".update": "auth.uid === data.userId",
        ".delete": "auth.uid === data.userId"
      }
    }
  }
}